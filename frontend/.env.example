# Firebase config — get these from Firebase Console > Project Settings > General > Your apps > Web app
# Copy this file to .env and fill in your own project's values.
# Without these set, the app runs but authentication is disabled (a clear notice is shown instead).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
